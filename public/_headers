# Netlify / Cloudflare Pages security headers
# Applied automatically when the file is in public/ and copied to dist/.
# For Lovable/Vercel deployments, see netlify.toml and vercel.json (mirror).

/*
  # Browser must speak HTTPS only to this site for the next year.
  # Add `; preload` only after submitting to https://hstspreload.org/.
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  # Blocks rendering inside <iframe> from any other origin — defeats clickjacking.
  X-Frame-Options: DENY
  # Tells browsers to trust the declared Content-Type and not sniff alternative types.
  X-Content-Type-Options: nosniff
  # On cross-origin nav: send only origin (no path/query) to upstream sites.
  Referrer-Policy: strict-origin-when-cross-origin
  # Disable powerful APIs the app doesn't use. Reduces attack surface from rogue libs.
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=(), usb=()
  # Cross-Origin-Opener-Policy isolates the browsing context (prevents window.opener attacks).
  Cross-Origin-Opener-Policy: same-origin
  # CSP — strict baseline.
  # NOTE: we keep 'unsafe-inline' on styles because shadcn/Tailwind ship inline
  # styles for runtime variants. Inline scripts are NOT allowed in production.
  # If you add a 3rd-party widget (e.g. HubSpot embed), extend script-src
  # explicitly with the exact host AND prefer SRI hashes over wildcards.
  Content-Security-Policy: default-src 'self'; script-src 'self' https://js.hsforms.net https://js-na1.hsforms.net https://js-na2.hsforms.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://*.hsforms.com https://*.hsforms.net https://*.hubspot.com; frame-src 'self' https://*.hsforms.net https://*.hubspot.com; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self'

# Hashed assets — long cache, since their URL changes on rebuild
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# HTML must always re-validate so users get the latest bundle pointer
/*.html
  Cache-Control: public, max-age=0, must-revalidate
