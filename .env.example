# Supabase (obrigatório para auth e dados)
# Crie um projeto em https://supabase.com e copie a URL e a chave anônima (anon/public).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# Opcional: ID do projeto (para ferramentas ou scripts)
# VITE_SUPABASE_PROJECT_ID=your-project-ref
